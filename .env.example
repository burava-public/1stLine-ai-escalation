FIRSTLINE_AI_ESCALATION_CONTROLLER_TOKEN=replace-with-controller-token
FIRSTLINE_API_TOKEN=replace-with-firstline-api-token
FIRSTLINE_ORG_CONTEXT=replace-with-org-uid-or-slug

FIRSTLINE_BASE_URL=https://1stline.burava.com
FIRSTLINE_MAILBOX_WEBSOCKET_URL=wss://1stline.burava.com/api/ai-escalation/mailbox
