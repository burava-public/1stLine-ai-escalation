OPENCODE_MODEL=replace-with-provider-model
OPENCODE_SMALL_MODEL=replace-with-provider-small-model
OPENCODE_DEFAULT_AGENT=firstline-concierge

# Optional: override base image reference used by Dockerfile and compose build.
CONTROLLER_BASE_IMAGE=ghcr.io/<org-or-user>/1stline-ai-escalation-controller:latest
